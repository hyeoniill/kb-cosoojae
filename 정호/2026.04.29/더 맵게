// 프로그래머스 : 더 맵게 LV2

import java.util.*;

class Solution {
    public int solution(int[] scoville, int K) {
        int answer = 0;
        PriorityQueue<Integer> pq = new PriorityQueue<>();
        for(int i : scoville) { // 스코빌 지수를 우선순위큐에 넣어서 자동으로 오름차순
            pq.add(i);
        }
        
        while(pq.peek() < K) {
            if(pq.size()<=1) { // 스코빌 지수를 K로 만들 수 없을 때 예외처리
                answer = -1;
                break;
            }
            int num = pq.poll();     // 제일 작은 스코빌 지수 값 꺼내기
            int p = num+(pq.poll()*2);  // 스코빌 지수 혼합 공식
            pq.add(p);                 // 새로운 스코빌 지수 큐에 추가
            answer++;
            
        }
        return answer;
    }
}
