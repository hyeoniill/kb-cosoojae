프로그래머스 : 피보나치 수 LV2

import java.util.*;

class Solution {
    static int mode = 1234567;
    public int solution(int n) {
        int answer = 0;
        int result = fib(n);
        return result;
    }
    
    static int fib(int n) {
        if(n <= 1) return n;

        int a = 0, b = 1;

        for(int i = 2; i <= n; i++) {
            int temp = (a + b)%mode;
            a = b;
            b = temp;
        }

        return b;
    }
}
