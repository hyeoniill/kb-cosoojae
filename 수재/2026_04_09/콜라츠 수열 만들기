import java.util.*;

class Solution {
    public int[] solution(int n) {
        int[] answer = {};
        
        for(;;) {
            answer = Arrays.copyOf(answer, answer.length + 1);
            answer[answer.length - 1] = n;
            if (n == 1) {
                break;
            }
            else if (n % 2 == 0) {
                n = n / 2;
            }
            else {
                n = n * 3 + 1;
            }
        }
        
        return answer;
    }
}
