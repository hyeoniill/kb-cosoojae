#include <bits/stdc++.h>

using namespace std;

string solution(vector<int> numbers, string hand) {
    
    vector<int> left = {0,3};
    vector<int> right = {2,3};
    int x = 0;
    int y = 0;
    int d_left = 0;
    int d_right = 0;
    string answer = "";
    
    for(int i =0; i<numbers.size(); i++){
        int num = numbers[i];
        if(num == 0){
            x = 1;
            y = 3;
        }else{
            x = (num -1)%3;
            y = (num -1)/3;
        }
        
        if(x == 0){
            left = {x,y};
            answer += 'L';
        }else if( x == 2){
            right = {x,y};
            answer += 'R';
        }else if ( x == 1){
            d_left = abs(left[0] - x) + abs(left[1]-y);
            d_right = abs(right[0] - x) + abs(right[1]-y);
            if(d_left > d_right){
                right = {x,y};
                answer += 'R';
            }else if(d_left < d_right){
                left = {x,y};
                answer += 'L';
            }else{
                if(hand == "right"){
                    right = {x,y};
                    answer += 'R';
                }else{
                    left = {x,y};
                    answer += 'L';
                }
            }
        }
        
    }
    return answer;
}
